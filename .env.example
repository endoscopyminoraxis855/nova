# Nova Configuration
# Copy to .env and customize. All values shown are defaults.

# --- LLM Provider ---
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:27b
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text-v2-moe

# Cloud provider API keys (required when LLM_PROVIDER != ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# --- MCP (Model Context Protocol) ---
ENABLE_MCP=true
MCP_CONFIG_DIR=/data/mcp
ENABLE_MCP_SERVER=true
MCP_SERVER_NAME=nova

# --- Search ---
SEARXNG_URL=http://searxng:8080

# --- Security ---
SYSTEM_ACCESS_LEVEL=sandboxed
NOVA_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173
ENABLE_INJECTION_DETECTION=true
REQUIRE_SIGNED_SKILLS=true

# --- Tool Timeouts ---
TOOL_TIMEOUT=120
GENERATION_TIMEOUT=480

# --- Learning ---
TRAINING_DATA_CHANNELS=api

# --- Channels (leave empty to disable) ---
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ALLOWED_USERS=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USERS=

# WhatsApp (Business API)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_CHAT_ID=
WHATSAPP_ALLOWED_USERS=

# Signal (signal-cli REST API)
SIGNAL_API_URL=
SIGNAL_PHONE_NUMBER=
SIGNAL_CHAT_ID=
SIGNAL_ALLOWED_USERS=
SIGNAL_POLL_INTERVAL=2

# --- Fine-tuning ---
FINETUNE_MIN_NEW_PAIRS=50
FINETUNE_OUTPUT_DIR=/data/finetune
FINETUNE_EVAL_HOLDOUT=10

# --- Server ---
HOST=0.0.0.0
PORT=8000
